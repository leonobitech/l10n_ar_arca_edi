<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="account_move_view_form_arca" model="ir.ui.view">
        <field name="name">account.move.form.arca</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Add CAE button in the header -->
            <xpath expr="//header" position="inside">
                <button name="action_request_cae"
                    type="object"
                    string="Request CAE"
                    class="btn-secondary"
                    invisible="l10n_ar_arca_cae or state != 'posted' or country_code != 'AR'"
                    groups="account.group_account_invoice"/>
                <button name="action_verify_arca"
                    type="object"
                    string="Verify CAE"
                    class="btn-secondary"
                    invisible="not l10n_ar_arca_cae or state != 'posted' or country_code != 'AR'"
                    groups="account.group_account_invoice"/>
            </xpath>
            <!-- Add ARCA fields in a new page -->
            <xpath expr="//page[@id='other_tab']" position="after">
                <page string="ARCA" name="arca_tab"
                    invisible="country_code != 'AR' or not l10n_ar_arca_cae">
                    <group>
                        <group string="Electronic Invoice">
                            <field name="l10n_ar_arca_cae"/>
                            <field name="l10n_ar_arca_cae_due_date"/>
                            <field name="l10n_ar_arca_result" widget="badge"
                                decoration-success="l10n_ar_arca_result == 'A'"
                                decoration-danger="l10n_ar_arca_result == 'R'"
                                decoration-warning="l10n_ar_arca_result == 'O'"/>
                        </group>
                        <group string="Barcode">
                            <field name="l10n_ar_arca_barcode"/>
                        </group>
                    </group>
                    <group string="Observations"
                        invisible="not l10n_ar_arca_observations">
                        <field name="l10n_ar_arca_observations" nolabel="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Show CAE in list view -->
    <record id="account_move_view_list_arca" model="ir.ui.view">
        <field name="name">account.move.list.arca</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="before">
                <field name="l10n_ar_arca_cae" optional="hide" string="CAE"/>
            </xpath>
        </field>
    </record>

</odoo>

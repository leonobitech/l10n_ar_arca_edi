<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="account_journal_view_form_arca" model="ir.ui.view">
        <field name="name">account.journal.form.arca</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="l10n_ar.account_journal_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='l10n_ar_afip_pos_system']" position="after">
                <field name="l10n_ar_arca_edi_enabled"
                    invisible="not l10n_ar_is_pos"/>
            </xpath>
        </field>
    </record>

</odoo>

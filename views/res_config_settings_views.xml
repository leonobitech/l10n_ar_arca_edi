<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_arca" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.arca</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='account']" position="inside">
                <block title="ARCA Electronic Invoicing"
                    invisible="not is_account_peppol_eligible">
                    <setting string="ARCA Certificate"
                        help="Select the active digital certificate for ARCA electronic invoicing.">
                        <field name="l10n_ar_arca_certificate_id"
                            domain="[('company_id', '=', company_id), ('state', '=', 'active')]"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>

</odoo>

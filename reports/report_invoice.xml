<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Override l10n_ar custom_header: company name + right side     -->
    <!-- ============================================================ -->
    <template id="custom_header" inherit_id="l10n_ar.custom_header">

        <!-- Make company name more prominent -->
        <xpath expr="//span[@t-field='o.company_id.partner_id.name']" position="replace">
            <strong style="font-size: 1.3em;" t-field="o.company_id.partner_id.name"/>
        </xpath>

        <!-- Replace right side: invoice number, date, fiscal data -->
        <div id="l10n_ar_header_right" position="replace">
            <div id="l10n_ar_header_right" class="col-6 text-end" style="padding-left: 0px;">
                <t t-if="not pre_printed_report">
                    <div>
                        Factura N°
                        <strong t-out="report_number"/>
                    </div>
                </t>
                <div>
                    Fecha de Factura:
                    <strong t-out="report_date" t-options='{"widget": "date"}'/>
                </div>
                <t t-if="not pre_printed_report">
                    <div style="margin-top: 2px;">
                        <span t-field="o.company_id.l10n_ar_afip_responsibility_type_id"/>
                    </div>
                    <div>
                        CUIT:
                        <strong t-field="o.company_id.partner_id.l10n_ar_formatted_vat"/>
                    </div>
                    <div style="font-size: 0.9em;">
                        IIBB:
                        <span t-if="o.company_id.l10n_ar_gross_income_type == 'exempt'">Exento</span>
                        <span t-elif="o.company_id.l10n_ar_gross_income_number" t-out="o.company_id.l10n_ar_gross_income_number"/>
                        <span t-else="">No inscripto</span>
                        <span t-if="o.company_id.l10n_ar_afip_start_date">
                             | Inicio Act.: <span t-field="o.company_id.l10n_ar_afip_start_date"/>
                        </span>
                    </div>
                </t>
            </div>
        </div>

    </template>

    <!-- ============================================================ -->
    <!-- Override invoice document: keep original client section,      -->
    <!-- only change footer (QR + CAE)                                -->
    <!-- ============================================================ -->
    <template id="report_invoice_document"
        inherit_id="l10n_ar.report_invoice_document">

        <!-- Replace the custom_footer to include CAE and QR code -->
        <t t-set="custom_footer" position="replace">
            <t t-set="custom_footer">
                <div class="row" style="font-size: 0.85em; margin-bottom: 15px;">
                    <t t-if="o.l10n_ar_arca_cae">
                        <div class="col-2 text-start" style="padding-left: 15px;">
                            <t t-if="o.l10n_ar_arca_qr_code">
                                <img t-att-src="'/report/barcode/?barcode_type=QR&amp;value=%s&amp;width=150&amp;height=150' % o.l10n_ar_arca_qr_code"
                                    style="width: 80px; height: 80px;"
                                    alt="ARCA QR Code"/>
                            </t>
                        </div>
                        <div class="col-6 text-start" style="padding-top: 16px;">
                            <strong>C.A.E. N°:</strong> <span t-field="o.l10n_ar_arca_cae"/><br/>
                            <strong>Fecha Vto. CAE:</strong>
                            <t t-set="cae_due" t-value="o.l10n_ar_arca_cae_due_date"/>
                            <span t-if="cae_due and len(cae_due) == 8"
                                t-out="'%s/%s/%s' % (cae_due[6:8], cae_due[4:6], cae_due[0:4])"/>
                            <span t-else="" t-out="cae_due"/>
                        </div>
                        <div name="footer_right_column" class="col-4 text-end">
                            <div name="pager" t-if="report_type == 'pdf'">
                                Page: <span class="page"/> / <span class="topage"/>
                            </div>
                        </div>
                    </t>
                    <t t-else="">
                        <div name="footer_left_column" class="col-8 text-start">
                        </div>
                        <div name="footer_right_column" class="col-4 text-end">
                            <div name="pager" t-if="report_type == 'pdf'">
                                Page: <span class="page"/> / <span class="topage"/>
                            </div>
                        </div>
                    </t>
                </div>
            </t>
        </t>

    </template>

    <!-- ============================================================ -->
    <!-- Override "Total" label to "TOTAL A PAGAR"                    -->
    <!-- ============================================================ -->
    <template id="document_tax_totals_template"
        inherit_id="account.document_tax_totals_template">
        <xpath expr="//tr[@class='o_total']/td/strong" position="replace">
            <strong>TOTAL A PAGAR</strong>
        </xpath>
    </template>

</odoo>

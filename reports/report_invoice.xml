<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Override l10n_ar custom_header: better visual hierarchy       -->
    <!-- ============================================================ -->
    <template id="custom_header" inherit_id="l10n_ar.custom_header">

        <!-- Replace company info (left side) with structured layout -->
        <xpath expr="//div[@style='padding-right: 0px;']" position="replace">
            <div class="col-6" style="padding-right: 0px;">
                <t t-if="not pre_printed_report">
                    <!-- Company name - prominent -->
                    <strong style="font-size: 1.3em;" t-field="o.company_id.partner_id.name"/>

                    <!-- Address - smaller -->
                    <div style="font-size: 0.80em; margin-top: 2px;">
                        <t t-out="', '.join([item for item in [header_address.street, header_address.street2, header_address.city] if item])"/>
                    </div>
                    <div style="font-size: 0.80em;">
                        <t t-out="', '.join([item for item in [header_address.state_id and header_address.state_id.name, header_address.country_id and header_address.country_id.name] if item])"/><t t-if="header_address.zip" t-out="'.'"/>
                    </div>

                    <!-- Contact info -->
                    <div style="margin-top: 3px; margin-bottom: 8px; font-size: 0.9em;">
                        <span t-if="header_address.phone" style="white-space: nowrap;">
                            <strong>Tel:</strong> <span t-out="header_address.phone"/>
                        </span>
                        <div t-if="header_address.email">
                            <strong>Email:</strong> <span t-out="header_address.email"/>
                        </div>
                        <div t-if="header_address.website">
                            <span t-out="(header_address.website or '').replace('https://', '').replace('http://', '')"/>
                        </div>
                    </div>
                </t>
            </div>
        </xpath>

        <!-- Replace right side: invoice number, date, fiscal data -->
        <div id="l10n_ar_header_right" position="replace">
            <div id="l10n_ar_header_right" class="col-6 text-end" style="padding-left: 0px; font-size: 0.95em;">
                <t t-if="not pre_printed_report">
                    <!-- Invoice number -->
                    <div>
                        <span style="color: #000;">Factura N°</span>
                        <strong t-out="report_number"/>
                    </div>
                </t>

                <!-- Date -->
                <div>
                    <span style="color: #000;">Fecha de Factura:</span>
                    <strong t-out="report_date" t-options='{"widget": "date"}'/>
                </div>

                <t t-if="not pre_printed_report">
                    <!-- Responsibility + CUIT -->
                    <div style="margin-top: 2px;">
                        <span t-field="o.company_id.l10n_ar_afip_responsibility_type_id"/>
                    </div>
                    <div>
                        <span style="color: #000;">CUIT:</span>
                        <strong t-field="o.company_id.partner_id.l10n_ar_formatted_vat"/>
                    </div>

                    <!-- IIBB + Activities Start -->
                    <div style="font-size: 0.9em; color: #000;">
                        <span>IIBB: </span>
                        <span t-if="o.company_id.l10n_ar_gross_income_type == 'exempt'">Exento</span>
                        <span t-elif="o.company_id.l10n_ar_gross_income_number" t-out="o.company_id.l10n_ar_gross_income_number"/>
                        <span t-else="">No inscripto</span>
                        <span t-if="o.company_id.l10n_ar_afip_start_date">
                             | Inicio Act.: <span t-field="o.company_id.l10n_ar_afip_start_date"/>
                        </span>
                    </div>
                </t>
            </div>
        </div>

    </template>

    <!-- ============================================================ -->
    <!-- Override informations section: customer + invoice details     -->
    <!-- ============================================================ -->
    <template id="report_invoice_document"
        inherit_id="l10n_ar.report_invoice_document">

        <!-- Replace informations section with better layout -->
        <div id="informations" position="replace">
            <div id="informations" class="row mt-2 mb-2" style="border: 1px solid #dee2e6; border-radius: 4px; padding: 8px 12px; margin-left: 0; margin-right: 0;">
                <div class="col-7" style="border-right: 1px solid #dee2e6; padding-right: 12px;">

                    <!-- Customer label -->
                    <div style="font-size: 0.8em; color: #000; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 2px;">
                        <t t-if="o.is_sale_document(include_receipts=True)">Cliente</t>
                        <t t-else="">Proveedor</t>
                    </div>

                    <!-- Customer name - prominent -->
                    <strong style="font-size: 1.05em;" t-field="o.partner_id.commercial_partner_id.name"/>

                    <!-- Address -->
                    <div style="font-size: 0.9em; color: #000; margin-top: 2px;">
                        <span t-field="o.partner_id" t-options="{'widget': 'contact', 'fields': ['address'], 'no_marker': true, 'no_tag_br': True}"/>
                    </div>

                    <!-- VAT Condition + Document -->
                    <div style="margin-top: 4px; font-size: 0.9em;">
                        <strong>Cond. IVA:</strong> <span t-field="o.partner_id.l10n_ar_afip_responsibility_type_id"/>
                    </div>

                    <t t-if="o.partner_id.vat and o.partner_id.l10n_latam_identification_type_id and o.partner_id.l10n_latam_identification_type_id.l10n_ar_afip_code != '99'">
                        <div style="font-size: 0.9em;">
                            <strong><t t-out="o.partner_id.l10n_latam_identification_type_id.name or o.company_id.account_fiscal_country_id.vat_label" id="inv_tax_id_label"/>:</strong>
                            <span t-out="o.partner_id.l10n_ar_formatted_vat if o.partner_id.l10n_ar_vat else o.partner_id.vat"/>
                        </div>
                    </t>

                </div>
                <div class="col-5" style="padding-left: 12px;">

                    <!-- Due Date - prominent -->
                    <t t-if="o.invoice_date_due">
                        <div style="margin-bottom: 6px;">
                            <div style="font-size: 0.8em; color: #000; text-transform: uppercase; letter-spacing: 0.5px;">Vencimiento</div>
                            <strong style="font-size: 1.05em;" t-field="o.invoice_date_due"/>
                        </div>
                    </t>

                    <!-- Payment Terms -->
                    <t t-if="o.invoice_payment_term_id" name="payment_term">
                        <div style="font-size: 0.9em;">
                            <strong>Cond. Pago:</strong>
                            <span t-field="o.invoice_payment_term_id.name"/>
                        </div>
                    </t>

                    <!-- Source -->
                    <t t-if="o.invoice_origin">
                        <div style="font-size: 0.9em;">
                            <strong>Origen:</strong>
                            <span t-field="o.invoice_origin"/>
                        </div>
                    </t>

                    <!-- Reference -->
                    <t t-if="o.ref">
                        <div style="font-size: 0.9em;">
                            <strong>Referencia:</strong>
                            <span t-field="o.ref"/>
                        </div>
                    </t>

                    <!-- Incoterm -->
                    <t t-if="o.invoice_incoterm_id">
                        <div style="font-size: 0.9em;">
                            <strong>Incoterm:</strong>
                            <span t-if="o.incoterm_location">
                                <span t-field="o.invoice_incoterm_id.code"/>
                                <span t-field="o.incoterm_location"/>
                            </span>
                            <span t-else="" t-field="o.invoice_incoterm_id.name"/>
                        </div>
                    </t>

                </div>
            </div>
        </div>

        <!-- Replace the custom_footer to include CAE and QR code -->
        <t t-set="custom_footer" position="replace">
            <t t-set="custom_footer">
                <div class="row" style="font-size: 0.85em; margin-bottom: 15px;">
                    <!-- CAE + QR row -->
                    <t t-if="o.l10n_ar_arca_cae">
                        <div class="col-2 text-start" style="padding-left: 15px;">
                            <t t-if="o.l10n_ar_arca_qr_code">
                                <img t-att-src="'/report/barcode/?barcode_type=QR&amp;value=%s&amp;width=150&amp;height=150' % o.l10n_ar_arca_qr_code"
                                    style="width: 80px; height: 80px;"
                                    alt="ARCA QR Code"/>
                            </t>
                        </div>
                        <div class="col-6 text-start" style="padding-top: 16px;">
                            <strong>C.A.E. N°:</strong> <span t-field="o.l10n_ar_arca_cae"/><br/>
                            <strong>Fecha Vto. CAE:</strong>
                            <t t-set="cae_due" t-value="o.l10n_ar_arca_cae_due_date"/>
                            <span t-if="cae_due and len(cae_due) == 8"
                                t-out="'%s/%s/%s' % (cae_due[6:8], cae_due[4:6], cae_due[0:4])"/>
                            <span t-else="" t-out="cae_due"/>
                        </div>
                        <div name="footer_right_column" class="col-4 text-end">
                            <div name="pager" t-if="report_type == 'pdf'">
                                Page: <span class="page"/> / <span class="topage"/>
                            </div>
                        </div>
                    </t>
                    <!-- Fallback when no CAE -->
                    <t t-else="">
                        <div name="footer_left_column" class="col-8 text-start">
                        </div>
                        <div name="footer_right_column" class="col-4 text-end">
                            <div name="pager" t-if="report_type == 'pdf'">
                                Page: <span class="page"/> / <span class="topage"/>
                            </div>
                        </div>
                    </t>
                </div>
            </t>
        </t>

    </template>

    <!-- ============================================================ -->
    <!-- Override "Total" label to "TOTAL A PAGAR"                    -->
    <!-- ============================================================ -->
    <template id="document_tax_totals_template"
        inherit_id="account.document_tax_totals_template">
        <xpath expr="//tr[@class='o_total']/td/strong" position="replace">
            <strong>TOTAL A PAGAR</strong>
        </xpath>
    </template>

</odoo>
